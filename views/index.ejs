<section class="hero-section">
    <h1>Welcome to CSE Motors!</h1>

    <%- messages() %>

    <div class="delorean-container">
        <div class="delorean-details">
            <h2>DMC Delorean</h2>
            <ul>
                <li>3 Cup holders</li>
                <li>Superman doors</li>
                <li>Fuzzy dice!</li>
            </ul>
            <button class="own-today-btn">Own Today</button>
        </div>
        <div class="delorean-image">
            <img src="/images/vehicles/delorean-tn.jpg" alt="Delorean tn">
        </div>
    </div>
</section>

<div class="bottom-content">
    <section class="reviews">
        <h3>DMC Delorean Reviews</h3>
        <ul>
            <li>"So fast it's almost like traveling in time." (4/5)</li>
            <li>"Coolest ride on the road." (4/5)</li>
            <li>"I'm feeling McFly!" (5/5)</li>
            <li>"The most futuristic ride of our day." (4.5/5)</li>
            <li>"80's livin and I love it!" (5/5)</li>
        </ul>
    </section>

    <section class="upgrades">
        <h3>Delorean upgrades</h3>
        <div class="upgrade-grid">
            <div class="upgrade-item">
                <div class="img-box"><img src="/images/upgrades/bumper_sticker.jpg" alt="bumper_sticker"></div>
                <a href="#">Bumper Sticker</a>
            </div>
            <div class="upgrade-item">
                <div class="img-box"><img src="/images/upgrades/flame.jpg" alt="flame"></div>
                <a href="#">Flame</a>
            </div>
            <div class="upgrade-item">
                <div class="img-box"><img src="/images/upgrades/flux-cap.png" alt="flux_cap"></div>
                <a href="#">Flux Capacitor</a>
            </div>
            <div class="upgrade-item">
                <div class="img-box"><img src="/images/upgrades/hub-cap.jpg" alt="hub-cap"></div>
                <a href="#">Hub Capacitor</a>
            </div>
        </div>
    </section>
</div>